#!/usr/bin/env bash
set -euo pipefail

INSTALL_DIR="${PROXMASTER_INSTALL_DIR:-/opt/proxmaster}"
ENV_FILE="${PROXMASTER_ENV_FILE:-$INSTALL_DIR/infra/.env}"
COMPOSE_FILE="${PROXMASTER_COMPOSE_FILE:-$INSTALL_DIR/infra/docker-compose.yml}"
INSTALLER_SCRIPT="${PROXMASTER_INSTALLER_SCRIPT:-$INSTALL_DIR/infra/bootstrap/install-node1.sh}"
API_BASE="${PROXMASTER_API_BASE_URL:-http://127.0.0.1:8080}"
AUTO_INSTALL_WG_TOOLS="${PROXMASTER_AUTO_INSTALL_WIREGUARD_TOOLS:-true}"

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "[proxmaster] missing command: $1" >&2
    exit 1
  }
}

ensure_env() {
  if [ ! -f "$ENV_FILE" ]; then
    echo "[proxmaster] missing env file: $ENV_FILE" >&2
    exit 1
  fi
}

token() {
  ensure_env
  awk -F= '/^PROXMASTER_ADMIN_TOKEN=/{print $2}' "$ENV_FILE"
}

docker_bin() {
  if docker info >/dev/null 2>&1; then
    echo "docker"
    return
  fi
  if command -v sudo >/dev/null 2>&1 && sudo docker info >/dev/null 2>&1; then
    echo "sudo docker"
    return
  fi
  echo "docker"
}

compose() {
  local db
  db="$(docker_bin)"
  if [ "$db" = "sudo docker" ]; then
    sudo docker compose -f "$COMPOSE_FILE" --env-file "$ENV_FILE" "$@"
    return
  fi
  docker compose -f "$COMPOSE_FILE" --env-file "$ENV_FILE" "$@"
}

install_wrappers() {
  local src="$INSTALL_DIR/infra/ops/cli/proxmaster"
  if [ ! -f "$src" ]; then
    return
  fi
  if [ -w /usr/local/bin ]; then
    install -m 0755 "$src" /usr/local/bin/pm || true
    install -m 0755 "$src" /usr/local/bin/proxmaster || true
    return
  fi
  if command -v sudo >/dev/null 2>&1; then
    sudo install -m 0755 "$src" /usr/local/bin/pm >/dev/null 2>&1 || true
    sudo install -m 0755 "$src" /usr/local/bin/proxmaster >/dev/null 2>&1 || true
  fi
}

ensure_repo_writable() {
  if [ -w "$INSTALL_DIR/.git" ] && [ -w "$INSTALL_DIR/.git/objects" ]; then
    return
  fi
  echo "[proxmaster] fixing repository permissions in $INSTALL_DIR ..."
  if ! command -v sudo >/dev/null 2>&1; then
    echo "[proxmaster] sudo not available; cannot repair repo permissions" >&2
    exit 1
  fi
  sudo chown -R "$USER:$USER" "$INSTALL_DIR"
  if [ ! -w "$INSTALL_DIR/.git" ] || [ ! -w "$INSTALL_DIR/.git/objects" ]; then
    echo "[proxmaster] repository is still not writable after chown" >&2
    exit 1
  fi
}

ensure_wireguard_tools() {
  if [ "$AUTO_INSTALL_WG_TOOLS" != "true" ]; then
    return
  fi
  if command -v wg >/dev/null 2>&1; then
    return
  fi
  echo "[proxmaster] wireguard tools missing; installing ..."
  if command -v sudo >/dev/null 2>&1; then
    sudo apt-get update -y >/dev/null 2>&1 || true
    sudo apt-get install -y wireguard wireguard-tools >/dev/null 2>&1 || true
  elif [ "${EUID:-$(id -u)}" -eq 0 ]; then
    apt-get update -y >/dev/null 2>&1 || true
    apt-get install -y wireguard wireguard-tools >/dev/null 2>&1 || true
  fi
  if ! command -v wg >/dev/null 2>&1; then
    echo "[proxmaster] warning: wireguard tools still unavailable (install manually if needed)" >&2
  fi
}

wait_health() {
  local max_tries="${1:-30}"
  local sleep_sec="${2:-2}"
  local i
  for i in $(seq 1 "$max_tries"); do
    if curl -fsS "$API_BASE/healthz" >/dev/null 2>&1; then
      return 0
    fi
    sleep "$sleep_sec"
  done
  return 1
}

cmd_update() {
  need_cmd git
  need_cmd docker
  ensure_env
  git config --global --add safe.directory "$INSTALL_DIR" >/dev/null 2>&1 || true
  ensure_repo_writable

  local has_local_changes="false"
  if ! git -C "$INSTALL_DIR" diff --quiet; then
    has_local_changes="true"
  fi
  if ! git -C "$INSTALL_DIR" diff --cached --quiet; then
    has_local_changes="true"
  fi
  if [ -n "$(git -C "$INSTALL_DIR" ls-files --others --exclude-standard)" ]; then
    has_local_changes="true"
  fi

  if [ "$has_local_changes" = "true" ]; then
    local backup_file
    backup_file="/tmp/proxmaster-local-changes-$(date +%Y%m%d-%H%M%S).patch"
    git -C "$INSTALL_DIR" diff >"$backup_file" || true
    echo "[proxmaster] local changes detected; backup written to $backup_file"
    git -C "$INSTALL_DIR" reset --hard HEAD
    git -C "$INSTALL_DIR" clean -fd
  fi

  git -C "$INSTALL_DIR" fetch origin main --prune
  git -C "$INSTALL_DIR" checkout main
  git -C "$INSTALL_DIR" reset --hard origin/main
  install_wrappers
  if [ -f "$INSTALL_DIR/backend/go.mod" ]; then
    local db
    db="$(docker_bin)"
    if [ "$db" = "sudo docker" ]; then
      sudo docker run --rm -v "$INSTALL_DIR/backend:/src" -w /src golang:1.22 go mod tidy >/dev/null 2>&1 || true
    else
      docker run --rm -v "$INSTALL_DIR/backend:/src" -w /src golang:1.22 go mod tidy >/dev/null 2>&1 || true
    fi
  fi
  ensure_wireguard_tools
  compose up -d --build
  if ! wait_health 45 2; then
    echo "[proxmaster] API not healthy after deploy. Last logs:" >&2
    compose logs --tail=120 proxmaster-api >&2 || true
    exit 1
  fi
  echo "[proxmaster] update done"
}

cmd_bootstrap() {
  local mode="${1:-quick}"
  local installer="$INSTALLER_SCRIPT"
  if [ ! -f "$installer" ]; then
    echo "[proxmaster] installer not found at $installer" >&2
    exit 1
  fi
  if [ "$mode" != "quick" ] && [ "$mode" != "custom" ]; then
    echo "Usage: proxmaster bootstrap [quick|custom]" >&2
    exit 1
  fi
  if [ "$mode" = "quick" ]; then
    if [ "${EUID:-$(id -u)}" -eq 0 ]; then
      bash "$installer" --quick --non-interactive
    else
      sudo bash "$installer" --quick --non-interactive
    fi
    return
  fi
  if [ "${EUID:-$(id -u)}" -eq 0 ]; then
    bash "$installer"
  else
    sudo bash "$installer"
  fi
}

cmd_proof() {
  need_cmd curl
  need_cmd jq
  ensure_env
  if ! wait_health 30 2; then
    echo "[proxmaster] API health endpoint is not ready yet" >&2
    compose logs --tail=120 proxmaster-api >&2 || true
    exit 1
  fi
  local t
  t="$(token)"
  echo "== healthz =="
  curl -fsS "$API_BASE/healthz" | jq .
  echo "== connectivity =="
  curl -fsS -H "Authorization: Bearer $t" "$API_BASE/connectivity/status" | jq .
  echo "== gitops =="
  curl -fsS -H "Authorization: Bearer $t" "$API_BASE/gitops/status" | jq .
  echo "== breakglass =="
  curl -fsS -H "Authorization: Bearer $t" "$API_BASE/access/breakglass" | jq .
}

cmd_status() {
  ensure_env
  compose ps
}

cmd_logs() {
  ensure_env
  local svc="${1:-proxmaster-api}"
  compose logs --tail=200 "$svc"
}

cmd_restart() {
  ensure_env
  local svc="${1:-proxmaster-api}"
  compose restart "$svc"
}

cmd_token() {
  token
}

cmd_ip() {
  need_cmd awk
  need_cmd sed

  local ips=""
  if command -v ip >/dev/null 2>&1; then
    ips="$(ip -4 -o addr show scope global | awk '{print $4}' | cut -d/ -f1 | tr '\n' ' ')"
  fi
  if [ -z "$ips" ]; then
    ips="$(hostname -I 2>/dev/null || true)"
  fi
  ips="$(echo "$ips" | xargs || true)"
  if [ -z "$ips" ]; then
    echo "[proxmaster] no global IPv4 found"
    return
  fi
  echo "IPv4 addresses: $ips"
  for ipaddr in $ips; do
    echo "  - http://$ipaddr:8080/"
    echo "  - http://$ipaddr:8080/healthz"
  done
}

api_call() {
  local method="$1"
  local path="$2"
  local body="${3:-}"
  local t
  t="$(token)"
  if [ -n "$body" ]; then
    curl -fsS -X "$method" -H "Authorization: Bearer $t" -H "Content-Type: application/json" "$API_BASE$path" -d "$body"
    return
  fi
  curl -fsS -X "$method" -H "Authorization: Bearer $t" "$API_BASE$path"
}

cmd_wg_status() {
  need_cmd jq
  api_call GET /vpn/wireguard/status | jq .
}

cmd_wg_plan() {
  need_cmd jq
  api_call POST /vpn/wireguard/plan '{}' | jq .
}

cmd_wg_apply() {
  need_cmd jq
  local client_public_key="${1:-}"
  local endpoint="${2:-}"
  if [ -z "$client_public_key" ]; then
    echo "Usage: proxmaster wg-apply <client_public_key> [server_endpoint]" >&2
    exit 1
  fi
  local payload
  payload="$(jq -nc --arg cpk "$client_public_key" --arg ep "$endpoint" '{actor:"cli-admin",client_public_key:$cpk,server_endpoint:$ep,reauth_token:"reauth-ok",hardware_mfa:true,second_approver:"cli-admin"}')"
  api_call POST /vpn/wireguard/apply "$payload" | jq .
}

usage() {
  cat <<EOF
Usage: proxmaster <command>

Commands:
  update               Pull latest code and redeploy stack
  up                   Alias for update
  proof                Run quick health/connectivity proof checks
  pf                   Alias for proof
  status               Show docker compose status
  st                   Alias for status
  logs [service]       Show logs (default: proxmaster-api)
  lg [service]         Alias for logs
  restart [service]    Restart service (default: proxmaster-api)
  rs [service]         Alias for restart
  token                Print PROXMASTER_ADMIN_TOKEN
  tk                   Alias for token
  ip                   Show server IPv4 addresses + test URLs
  wg-status            WireGuard status
  wg-plan              WireGuard plan/template output
  wg-apply             Apply WireGuard config (guarded)
  bootstrap [quick]    One-command VM bootstrap (non-interactive quick mode)
  help                 Show this help
EOF
}

main() {
  local cmd="${1:-help}"
  shift || true
  case "$cmd" in
    up) cmd="update" ;;
    pf) cmd="proof" ;;
    st) cmd="status" ;;
    lg) cmd="logs" ;;
    rs) cmd="restart" ;;
    tk) cmd="token" ;;
    ipa) cmd="ip" ;;
    wgs) cmd="wg-status" ;;
    wgp) cmd="wg-plan" ;;
    wga) cmd="wg-apply" ;;
    bs) cmd="bootstrap" ;;
  esac
  case "$cmd" in
    update) cmd_update "$@" ;;
    proof) cmd_proof "$@" ;;
    status) cmd_status "$@" ;;
    logs) cmd_logs "$@" ;;
    restart) cmd_restart "$@" ;;
    token) cmd_token "$@" ;;
    ip) cmd_ip "$@" ;;
    wg-status) cmd_wg_status "$@" ;;
    wg-plan) cmd_wg_plan "$@" ;;
    wg-apply) cmd_wg_apply "$@" ;;
    bootstrap) cmd_bootstrap "$@" ;;
    help|-h|--help) usage ;;
    *)
      echo "[proxmaster] unknown command: $cmd" >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"
