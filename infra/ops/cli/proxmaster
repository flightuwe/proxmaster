#!/usr/bin/env bash
set -euo pipefail

INSTALL_DIR="${PROXMASTER_INSTALL_DIR:-/opt/proxmaster}"
ENV_FILE="${PROXMASTER_ENV_FILE:-$INSTALL_DIR/infra/.env}"
COMPOSE_FILE="${PROXMASTER_COMPOSE_FILE:-$INSTALL_DIR/infra/docker-compose.yml}"
INSTALLER_SCRIPT="${PROXMASTER_INSTALLER_SCRIPT:-$INSTALL_DIR/infra/bootstrap/install-node1.sh}"
API_BASE="${PROXMASTER_API_BASE_URL:-http://127.0.0.1:8080}"
AUTO_INSTALL_WG_TOOLS="${PROXMASTER_AUTO_INSTALL_WIREGUARD_TOOLS:-true}"
WG_INSTALL_RETRIES="${PROXMASTER_WIREGUARD_INSTALL_RETRIES:-3}"
WAIT_WRITES_MAX_TRIES="${PROXMASTER_WAIT_WRITES_MAX_TRIES:-30}"
HEARTBEAT_NODES="${PROXMASTER_HEARTBEAT_NODES:-node-1,node-2,node-3,node-4}"

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "[proxmaster] missing command: $1" >&2
    exit 1
  }
}

ensure_env() {
  if [ ! -f "$ENV_FILE" ]; then
    echo "[proxmaster] missing env file: $ENV_FILE" >&2
    exit 1
  fi
}

token() {
  ensure_env
  awk -F= '/^PROXMASTER_ADMIN_TOKEN=/{print $2}' "$ENV_FILE"
}

docker_bin() {
  if docker info >/dev/null 2>&1; then
    echo "docker"
    return
  fi
  if command -v sudo >/dev/null 2>&1 && sudo docker info >/dev/null 2>&1; then
    echo "sudo docker"
    return
  fi
  echo "docker"
}

compose() {
  local db
  db="$(docker_bin)"
  if [ "$db" = "sudo docker" ]; then
    sudo docker compose -f "$COMPOSE_FILE" --env-file "$ENV_FILE" "$@"
    return
  fi
  docker compose -f "$COMPOSE_FILE" --env-file "$ENV_FILE" "$@"
}

install_wrappers() {
  local src="$INSTALL_DIR/infra/ops/cli/proxmaster"
  if [ ! -f "$src" ]; then
    return
  fi
  local installed="false"
  if [ -w /usr/local/bin ]; then
    if install -m 0755 "$src" /usr/local/bin/pm && install -m 0755 "$src" /usr/local/bin/proxmaster; then
      installed="true"
    fi
  fi
  if [ "$installed" = "false" ] && command -v sudo >/dev/null 2>&1; then
    if sudo install -m 0755 "$src" /usr/local/bin/pm && sudo install -m 0755 "$src" /usr/local/bin/proxmaster; then
      installed="true"
    fi
  fi
  if [ "$installed" = "false" ]; then
    echo "[proxmaster] warning: could not refresh /usr/local/bin wrappers (pm/proxmaster)" >&2
  fi
}

ensure_repo_writable() {
  if [ -w "$INSTALL_DIR/.git" ] && [ -w "$INSTALL_DIR/.git/objects" ]; then
    return
  fi
  echo "[proxmaster] fixing repository permissions in $INSTALL_DIR ..."
  if ! command -v sudo >/dev/null 2>&1; then
    echo "[proxmaster] sudo not available; cannot repair repo permissions" >&2
    exit 1
  fi
  sudo chown -R "$USER:$USER" "$INSTALL_DIR"
  if [ ! -w "$INSTALL_DIR/.git" ] || [ ! -w "$INSTALL_DIR/.git/objects" ]; then
    echo "[proxmaster] repository is still not writable after chown" >&2
    exit 1
  fi
}

ensure_wireguard_tools() {
  if [ "$AUTO_INSTALL_WG_TOOLS" != "true" ]; then
    return
  fi
  if command -v wg >/dev/null 2>&1; then
    return
  fi
  echo "[proxmaster] wireguard tools missing; installing ..."
  local i
  local installer="apt-get"
  if command -v sudo >/dev/null 2>&1 && [ "${EUID:-$(id -u)}" -ne 0 ]; then
    installer="sudo apt-get"
  elif [ "${EUID:-$(id -u)}" -ne 0 ]; then
    echo "[proxmaster] cannot install wireguard tools without sudo/root" >&2
    exit 1
  fi

  for i in $(seq 1 "$WG_INSTALL_RETRIES"); do
    # Wait briefly for dpkg/apt locks from unattended jobs.
    local wait_try=0
    while [ -f /var/lib/dpkg/lock-frontend ] || [ -f /var/lib/apt/lists/lock ]; do
      wait_try=$((wait_try + 1))
      if [ "$wait_try" -gt 30 ]; then
        break
      fi
      sleep 2
    done

    if [ "$installer" = "sudo apt-get" ]; then
      sudo DEBIAN_FRONTEND=noninteractive apt-get update -y || true
      sudo DEBIAN_FRONTEND=noninteractive apt-get install -y wireguard wireguard-tools || \
        sudo DEBIAN_FRONTEND=noninteractive apt-get install -y wireguard-tools || true
    else
      DEBIAN_FRONTEND=noninteractive apt-get update -y || true
      DEBIAN_FRONTEND=noninteractive apt-get install -y wireguard wireguard-tools || \
        DEBIAN_FRONTEND=noninteractive apt-get install -y wireguard-tools || true
    fi

    if command -v wg >/dev/null 2>&1; then
      echo "[proxmaster] wireguard tools installed"
      return
    fi
    sleep 2
  done

  if command -v sudo >/dev/null 2>&1; then
    sudo apt-cache policy wireguard wireguard-tools || true
  fi
  echo "[proxmaster] failed to install wireguard tools automatically; cannot continue" >&2
  exit 1
}

wait_health() {
  local max_tries="${1:-30}"
  local sleep_sec="${2:-2}"
  local i
  for i in $(seq 1 "$max_tries"); do
    if curl -fsS "$API_BASE/healthz" >/dev/null 2>&1; then
      return 0
    fi
    sleep "$sleep_sec"
  done
  return 1
}

wait_writes_gate() {
  local max_tries="${1:-$WAIT_WRITES_MAX_TRIES}"
  local sleep_sec="${2:-2}"
  local i
  local t
  t="$(token)"
  for i in $(seq 1 "$max_tries"); do
    if curl -fsS -H "Authorization: Bearer $t" "$API_BASE/healthz" | jq -e '.health_gate.allow_writes == true' >/dev/null 2>&1; then
      return 0
    fi
    sleep "$sleep_sec"
  done
  return 1
}

seed_heartbeats() {
  local t
  t="$(token)"
  local node
  local list
  list="$(echo "$HEARTBEAT_NODES" | tr ',' ' ')"
  for node in $list; do
    node="$(echo "$node" | xargs)"
    if [ -z "$node" ]; then
      continue
    fi
    curl -fsS -X POST -H "Authorization: Bearer $t" -H "Content-Type: application/json" \
      "$API_BASE/nodes/heartbeat" -d "{\"node_id\":\"$node\"}" >/dev/null 2>&1 || true
  done
}

cmd_update() {
  need_cmd git
  need_cmd docker
  need_cmd jq
  ensure_env
  git config --global --add safe.directory "$INSTALL_DIR" >/dev/null 2>&1 || true
  ensure_repo_writable

  local has_local_changes="false"
  if ! git -C "$INSTALL_DIR" diff --quiet; then
    has_local_changes="true"
  fi
  if ! git -C "$INSTALL_DIR" diff --cached --quiet; then
    has_local_changes="true"
  fi
  if [ -n "$(git -C "$INSTALL_DIR" ls-files --others --exclude-standard)" ]; then
    has_local_changes="true"
  fi

  if [ "$has_local_changes" = "true" ]; then
    local backup_file
    backup_file="/tmp/proxmaster-local-changes-$(date +%Y%m%d-%H%M%S).patch"
    git -C "$INSTALL_DIR" diff >"$backup_file" || true
    echo "[proxmaster] local changes detected; backup written to $backup_file"
    git -C "$INSTALL_DIR" reset --hard HEAD
  fi

  # Always force-sync with remote to avoid stale wrappers and drift on long-lived VMs.
  git -C "$INSTALL_DIR" fetch --all --prune
  git -C "$INSTALL_DIR" checkout main
  git -C "$INSTALL_DIR" reset --hard origin/main
  git -C "$INSTALL_DIR" clean -fd
  install_wrappers
  if [ -f "$INSTALL_DIR/backend/go.mod" ]; then
    local db
    db="$(docker_bin)"
    if [ "$db" = "sudo docker" ]; then
      sudo docker run --rm -v "$INSTALL_DIR/backend:/src" -w /src golang:1.22 go mod tidy >/dev/null 2>&1 || true
    else
      docker run --rm -v "$INSTALL_DIR/backend:/src" -w /src golang:1.22 go mod tidy >/dev/null 2>&1 || true
    fi
  fi
  ensure_wireguard_tools
  compose up -d --build --force-recreate proxmaster-api runner-agent
  if ! wait_health 45 2; then
    echo "[proxmaster] API not healthy after deploy. Last logs:" >&2
    compose logs --tail=120 proxmaster-api >&2 || true
    exit 1
  fi
  seed_heartbeats
  if ! wait_writes_gate "$WAIT_WRITES_MAX_TRIES" 2; then
    echo "[proxmaster] warning: write gate still closed after update (runner heartbeat/quorum issue)" >&2
  fi
  echo "[proxmaster] update done"
}

cmd_bootstrap() {
  local mode="${1:-quick}"
  local installer="$INSTALLER_SCRIPT"
  if [ ! -f "$installer" ]; then
    echo "[proxmaster] installer not found at $installer" >&2
    exit 1
  fi
  if [ "$mode" != "quick" ] && [ "$mode" != "custom" ]; then
    echo "Usage: proxmaster bootstrap [quick|custom]" >&2
    exit 1
  fi
  if [ "$mode" = "quick" ]; then
    if [ "${EUID:-$(id -u)}" -eq 0 ]; then
      bash "$installer" --quick --non-interactive
    else
      sudo bash "$installer" --quick --non-interactive
    fi
    return
  fi
  if [ "${EUID:-$(id -u)}" -eq 0 ]; then
    bash "$installer"
  else
    sudo bash "$installer"
  fi
}

cmd_proof() {
  need_cmd curl
  need_cmd jq
  ensure_env
  if ! wait_health 30 2; then
    echo "[proxmaster] API health endpoint is not ready yet" >&2
    compose logs --tail=120 proxmaster-api >&2 || true
    exit 1
  fi
  local t
  t="$(token)"
  echo "== healthz =="
  curl -fsS "$API_BASE/healthz" | jq .
  echo "== connectivity =="
  curl -fsS -H "Authorization: Bearer $t" "$API_BASE/connectivity/status" | jq .
  echo "== gitops =="
  curl -fsS -H "Authorization: Bearer $t" "$API_BASE/gitops/status" | jq .
  echo "== breakglass =="
  curl -fsS -H "Authorization: Bearer $t" "$API_BASE/access/breakglass" | jq .
}

cmd_status() {
  ensure_env
  compose ps
}

cmd_logs() {
  ensure_env
  local svc="${1:-proxmaster-api}"
  compose logs --tail=200 "$svc"
}

cmd_restart() {
  ensure_env
  local svc="${1:-proxmaster-api}"
  compose restart "$svc"
}

cmd_token() {
  token
}

cmd_ip() {
  need_cmd awk
  need_cmd sed

  local ips=""
  if command -v ip >/dev/null 2>&1; then
    ips="$(ip -4 -o addr show scope global | awk '{print $4}' | cut -d/ -f1 | tr '\n' ' ')"
  fi
  if [ -z "$ips" ]; then
    ips="$(hostname -I 2>/dev/null || true)"
  fi
  ips="$(echo "$ips" | xargs || true)"
  if [ -z "$ips" ]; then
    echo "[proxmaster] no global IPv4 found"
    return
  fi
  echo "IPv4 addresses: $ips"
  for ipaddr in $ips; do
    echo "  - http://$ipaddr:8080/"
    echo "  - http://$ipaddr:8080/healthz"
  done
}

api_call() {
  local method="$1"
  local path="$2"
  local body="${3:-}"
  local t
  t="$(token)"
  if [ -n "$body" ]; then
    curl -fsS -X "$method" -H "Authorization: Bearer $t" -H "Content-Type: application/json" "$API_BASE$path" -d "$body"
    return
  fi
  curl -fsS -X "$method" -H "Authorization: Bearer $t" "$API_BASE$path"
}

cmd_wg_status() {
  need_cmd jq
  local data
  data="$(api_call GET /connectivity/status | jq '.wireguard // .')"
  local iface
  iface="$(echo "$data" | jq -r '.wireguard_interface // "wg0"')"
  local reason
  reason="$(echo "$data" | jq -r '.reason // ""')"

  if [[ "$reason" == *"unavailable"* || "$reason" == *"no permission"* ]]; then
    local host_raw=""
    if command -v wg >/dev/null 2>&1; then
      if host_raw="$(wg show "$iface" 2>/dev/null)"; then
        data="$(echo "$data" | jq --arg iface "$iface" --arg txt "$host_raw" '. + {host_check:{interface:$iface, available:true, detail:$txt}}')"
      elif command -v sudo >/dev/null 2>&1 && host_raw="$(sudo wg show "$iface" 2>/dev/null)"; then
        data="$(echo "$data" | jq --arg iface "$iface" --arg txt "$host_raw" '. + {host_check:{interface:$iface, available:true, detail:$txt}}')"
      else
        data="$(echo "$data" | jq --arg iface "$iface" '. + {host_check:{interface:$iface, available:false}}')"
      fi
    fi
  fi
  echo "$data" | jq .
}

cmd_wg_plan() {
  need_cmd jq
  api_call POST /vpn/wireguard/plan '{}' | jq .
}

cmd_wg_apply() {
  need_cmd jq
  local client_public_key="${1:-}"
  local endpoint="${2:-}"
  if [ -z "$client_public_key" ]; then
    echo "Usage: proxmaster wg-apply <client_public_key> [server_endpoint]" >&2
    exit 1
  fi
  local payload
  payload="$(jq -nc --arg cpk "$client_public_key" --arg ep "$endpoint" '{actor:"cli-admin",client_public_key:$cpk,server_endpoint:$ep,reauth_token:"reauth-ok",hardware_mfa:true,second_approver:"cli-admin"}')"
  api_call POST /vpn/wireguard/apply "$payload" | jq .
}

cmd_mcp() {
  need_cmd jq
  local tool="${1:-}"
  local params="${2:-{}}"
  if [ -z "$tool" ]; then
    echo "Usage: proxmaster mcp <tool> [json_params]" >&2
    exit 1
  fi
  if ! echo "$params" | jq -e . >/dev/null 2>&1; then
    echo "[proxmaster] invalid json params: $params" >&2
    exit 1
  fi
  local payload
  payload="$(jq -nc --arg t "$tool" --argjson p "$params" '{tool:$t, params:$p, actor:"cli-admin"}')"
  api_call POST /mcp/call "$payload" | jq .
}

cmd_autonomy_task() {
  need_cmd jq
  local tool="${1:-}"
  local payload="${2:-{}}"
  if [ -z "$tool" ]; then
    echo "Usage: proxmaster auto-task <tool> [json_payload]" >&2
    exit 1
  fi
  if ! echo "$payload" | jq -e . >/dev/null 2>&1; then
    echo "[proxmaster] invalid json payload: $payload" >&2
    exit 1
  fi
  local body
  body="$(jq -nc --arg t "$tool" --argjson p "$payload" '{type:$t,payload:$p,requested_by:"cli-admin"}')"
  api_call POST /autonomy/tasks "$body" | jq .
}

cmd_autonomy_tasks() {
  need_cmd jq
  api_call GET /autonomy/tasks | jq .
}

cmd_timeline() {
  need_cmd jq
  api_call GET /jobs/timeline | jq .
}

usage() {
  cat <<EOF
Usage: proxmaster <command>

Commands:
  update               Pull latest code and redeploy stack
  up                   Alias for update
  proof                Run quick health/connectivity proof checks
  pf                   Alias for proof
  status               Show docker compose status
  st                   Alias for status
  logs [service]       Show logs (default: proxmaster-api)
  lg [service]         Alias for logs
  restart [service]    Restart service (default: proxmaster-api)
  rs [service]         Alias for restart
  token                Print PROXMASTER_ADMIN_TOKEN
  tk                   Alias for token
  ip                   Show server IPv4 addresses + test URLs
  wg-status            WireGuard status
  wg-plan              WireGuard plan/template output
  wg-apply             Apply WireGuard config (guarded)
  mcp                  Execute MCP tool call (mcp <tool> [json_params])
  auto-task            Queue autonomy task (auto-task <tool> [json_payload])
  auto-tasks           List autonomy task queue
  timeline             Show jobs/tasks/audit/incident timeline
  tl                   Alias for timeline
  bootstrap [quick]    One-command VM bootstrap (non-interactive quick mode)
  help                 Show this help
EOF
}

main() {
  local cmd="${1:-help}"
  shift || true
  case "$cmd" in
    up) cmd="update" ;;
    pf) cmd="proof" ;;
    st) cmd="status" ;;
    lg) cmd="logs" ;;
    rs) cmd="restart" ;;
    tk) cmd="token" ;;
    ipa) cmd="ip" ;;
    wgs) cmd="wg-status" ;;
    wgp) cmd="wg-plan" ;;
    wga) cmd="wg-apply" ;;
    mc) cmd="mcp" ;;
    at) cmd="auto-task" ;;
    ats) cmd="auto-tasks" ;;
    tl) cmd="timeline" ;;
    bs) cmd="bootstrap" ;;
  esac
  case "$cmd" in
    update) cmd_update "$@" ;;
    proof) cmd_proof "$@" ;;
    status) cmd_status "$@" ;;
    logs) cmd_logs "$@" ;;
    restart) cmd_restart "$@" ;;
    token) cmd_token "$@" ;;
    ip) cmd_ip "$@" ;;
    wg-status) cmd_wg_status "$@" ;;
    wg-plan) cmd_wg_plan "$@" ;;
    wg-apply) cmd_wg_apply "$@" ;;
    mcp) cmd_mcp "$@" ;;
    auto-task) cmd_autonomy_task "$@" ;;
    auto-tasks) cmd_autonomy_tasks "$@" ;;
    timeline) cmd_timeline "$@" ;;
    bootstrap) cmd_bootstrap "$@" ;;
    help|-h|--help) usage ;;
    *)
      echo "[proxmaster] unknown command: $cmd" >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"
