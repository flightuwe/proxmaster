[Unit]
Description=Proxmaster Node Runner Agent
After=network.target

[Service]
Type=simple
User=root
Environment=RUNNER_LISTEN_ADDR=:9091
Environment=RUNNER_NODE_ID=node-1
Environment=RUNNER_SHARED_SECRET=change-me
ExecStart=/usr/local/bin/runner-agent
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
